# LibraFlow AI Service - Environment Variables
# Copy this file to .env and fill in the actual values

# Server Configuration
PORT=5000
NODE_ENV=production

# Mock Mode (set to 'true' for development/demo without real AI calls)
MOCK_MODE=false

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379
# Or for Upstash Redis:
# REDIS_URL=rediss://your-upstash-redis-url

# Google Cloud TTS Configuration (optional - for TTS feature)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Or set the JSON content directly:
# GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account",...}'

# Monitoring & Logging (optional)
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=info
